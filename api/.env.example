# ===== Supabase (acesso 100% server-side) =====
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# service role — usada só no servidor. NUNCA expor no front.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
# (anon key não é usada: o front nunca fala com o Supabase direto)

# ===== Datafy API (camada/BSP que expõe a API Oficial do WhatsApp, tipo Twilio) =====
# Base do host (SEM /v1 e SEM /media): mídia usa {base}/media/{id} e o
# Cloud API (envio) usa {base}/v1/...
DATAFY_API_URL=https://cloud.datafyapi.com.br
# token da instância/número (sempre no header Authorization: Bearer ...)
DATAFY_NUMBER_TOKEN=sk_live_xxx
DATAFY_PHONE_NUMBER_ID=

# ===== Pusher Channels (realtime) =====
# valores reais SÓ no .env (este arquivo é commitado!)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
